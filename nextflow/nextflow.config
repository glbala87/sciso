/*
 * sciso: single-cell isoform analysis
 * Nextflow configuration
 */

params {
    // --- Required inputs ---
    gene_matrix_dir = null
    transcript_matrix_dir = null
    gene_transcript_map = null

    // --- Optional inputs ---
    tagged_bam = null
    annotated_gtfs = null
    vcf = null
    sample_id = "sample"

    // --- Output ---
    out_dir = "iris_results"

    // --- Clustering ---
    cluster_method = "leiden"
    cluster_resolution = 1.0
    cluster_n_neighbors = 15
    cluster_n_pcs = 50
    isoform_cluster_resolution = 1.0
    min_isoforms_per_gene = 2
    diversity_metric = "shannon"

    // --- Cell type annotation ---
    cell_type_annotation = true
    annotation_method = "marker_overlap"
    species = "human"
    marker_genes_db = null
    min_marker_genes = 3

    // --- DTU ---
    differential_transcript_usage = true
    dtu_test_method = "chi_squared"
    dtu_min_cells = 10
    dtu_min_gene_counts = 20
    dtu_fdr_threshold = 0.05

    // --- Novel isoform discovery ---
    novel_isoform_discovery = true
    novel_min_cells = 3
    novel_min_counts = 5
    novel_enrichment_fdr = 0.05

    // --- Trajectory ---
    isoform_trajectory = true
    trajectory_n_neighbors = 15
    trajectory_n_pcs = 30
    trajectory_n_bins = 10

    // --- ASE ---
    allele_specific_expression = true
    ase_min_total_counts = 10
    ase_min_cells = 5
    ase_fdr_threshold = 0.05
}

process {
    withName: '.*' {
        conda = '../environment.yml'
    }
}

profiles {
    standard {
        process.executor = 'local'
    }
    conda {
        conda.enabled = true
    }
    docker {
        docker.enabled = true
        process.container = 'sciso:latest'
    }
    singularity {
        singularity.enabled = true
        process.container = 'sciso_latest.sif'
    }
}

manifest {
    name = 'sciso'
    author = 'sciso developers'
    description = 'Isoform-Resolved Inference for Single-cells'
    version = '0.1.0'
    nextflowVersion = '>=23.04.2'
}
